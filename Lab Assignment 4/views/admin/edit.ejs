<%- include('../partials/admin-header') %>

<div class="admin-form-card">
  <div class="table-header">
    <h3>Edit Product</h3>
    <a href="/admin" class="btn-admin btn-admin-secondary">
      <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
    </a>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div style="background-color: #fee2e2; border-left: 4px solid #ef4444; color: #b91c1c; padding: 1rem 2rem; font-size: 0.9rem; font-weight: 500;">
      <i class="fa-solid fa-triangle-exclamation" style="margin-right: 0.5rem;"></i> <%= error %>
    </div>
  <% } %>

  <form action="/admin/products/<%= product._id %>" method="POST" enctype="multipart/form-data">
    <div class="form-grid">
      
      <!-- Product Name -->
      <div class="admin-input-group form-group-full">
        <label for="name" class="admin-label">Product Name *</label>
        <input type="text" id="name" name="name" class="admin-input" value="<%= product.name %>" required />
      </div>

      <!-- Price -->
      <div class="admin-input-group">
        <label for="price" class="admin-label">Selling Price ($) *</label>
        <input type="number" id="price" name="price" step="0.01" min="0" class="admin-input" value="<%= product.price %>" required />
      </div>

      <!-- Original Price -->
      <div class="admin-input-group">
        <label for="originalPrice" class="admin-label">Original Price ($) *</label>
        <input type="number" id="originalPrice" name="originalPrice" step="0.01" min="0" class="admin-input" value="<%= product.originalPrice %>" required />
      </div>

      <!-- Category -->
      <div class="admin-input-group">
        <label for="category" class="admin-label">Category *</label>
        <select id="category" name="category" class="admin-select" required>
          <option value="electronics" <%= product.category === 'electronics' ? 'selected' : '' %>>Electronics</option>
          <option value="clothing" <%= product.category === 'clothing' ? 'selected' : '' %>>Clothing</option>
          <option value="books" <%= product.category === 'books' ? 'selected' : '' %>>Books</option>
          <option value="home" <%= product.category === 'home' ? 'selected' : '' %>>Home & Kitchen</option>
        </select>
      </div>

      <!-- Stock -->
      <div class="admin-input-group">
        <label for="stock" class="admin-label">Stock Quantity *</label>
        <input type="number" id="stock" name="stock" min="0" class="admin-input" value="<%= product.stock %>" required />
      </div>

      <!-- Promo Badge -->
      <div class="admin-input-group">
        <label for="badge" class="admin-label">Promo Badge (Optional)</label>
        <input type="text" id="badge" name="badge" class="admin-input" value="<%= product.badge %>" />
      </div>

      <!-- Rating (1-5) -->
      <div class="admin-input-group">
        <label for="rating" class="admin-label">Rating (1-5)</label>
        <input type="number" id="rating" name="rating" min="1" max="5" step="0.1" value="<%= product.rating %>" class="admin-input" required />
      </div>

      <!-- Description -->
      <div class="admin-input-group form-group-full">
        <label for="description" class="admin-label">Product Description</label>
        <textarea id="description" name="description" class="admin-textarea"><%= product.description %></textarea>
      </div>

      <!-- Image Upload Area -->
      <div class="admin-input-group form-group-full">
        <label class="admin-label">Product Image (Leave blank to keep existing)</label>
        <div class="file-upload-wrap">
          <i class="fa-solid fa-cloud-arrow-up"></i>
          <span class="file-upload-text">Drag and drop your image, or browse</span>
          <span class="file-upload-subtext">Supports PNG, JPG, JPEG (Max 5MB)</span>
          <input type="file" name="image" class="file-upload-input" accept="image/*" />
        </div>
        <div class="image-preview-area">
          <% if (product.image) { %>
            <img src="<%= product.image %>" class="image-preview-thumb" alt="Current Image" onerror="this.src='https://placehold.co/150x150?text=Product'"/>
          <% } %>
        </div>
      </div>

    </div>

    <div class="form-actions-bar">
      <a href="/admin" class="btn-admin btn-admin-secondary">Cancel</a>
      <button type="submit" class="btn-admin btn-admin-primary">
        <i class="fa-solid fa-floppy-disk"></i> Update Product
      </button>
    </div>
  </form>
</div>

<%- include('../partials/admin-footer') %>
