<%- include('partials/header') %>

<div class="container" style="padding-top: 4rem; padding-bottom: 6rem; max-width: 800px;">
  
  <!-- Success Card -->
  <div style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.4); border-radius: 24px; padding: 3rem; box-shadow: 0 20px 40px rgba(0,0,0,0.03); text-align: center; margin-bottom: 2rem;">
    
    <!-- Animated Checkmark -->
    <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; background-color: #dcfce7; border-radius: 50%; color: #166534; font-size: 2.5rem; margin-bottom: 1.5rem; animation: pulseSuccess 2s infinite;">
      <i class="fa-solid fa-circle-check" style="animation: scaleUp 0.5s ease-out;"></i>
    </div>

    <!-- Success Message -->
    <h1 style="font-size: 2rem; font-weight: 800; color: #0f172a; margin: 0 0 0.5rem 0;">Thank You for Your Order!</h1>
    <p style="color: #64748b; font-size: 1.05rem; margin-bottom: 2.5rem;">Your transaction has been approved and stock was successfully allocated. A confirmation email has been sent.</p>

    <!-- Invoice Sheet -->
    <div class="invoice-box" style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 2rem; text-align: left; box-shadow: 0 4px 6px rgba(0,0,0,0.01);">
      
      <!-- Invoice Header -->
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px dashed #e2e8f0; padding-bottom: 1.5rem; margin-bottom: 1.5rem;">
        <div>
          <h3 style="margin: 0 0 0.25rem 0; font-size: 1.2rem; font-weight: 700; color: #0f172a;">ShopZone Invoice</h3>
          <span style="font-size: 0.85rem; color: #64748b;">Order #: <strong><%= orderNumber %></strong></span>
        </div>
        <div style="text-align: right;">
          <span style="font-size: 0.85rem; color: #64748b; display: block;">Date</span>
          <span style="font-weight: 600; color: #334155; font-size: 0.9rem;"><%= date %></span>
        </div>
      </div>

      <!-- Item Row -->
      <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #f1f5f9;">
        <img src="<%= product.image %>" alt="<%= product.name %>" style="width: 70px; height: 70px; object-fit: contain; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0; padding: 4px;"/>
        <div style="flex-grow: 1;">
          <h4 style="margin: 0 0 0.25rem 0; font-size: 1rem; font-weight: 700; color: #0f172a;"><%= product.name %></h4>
          <span style="font-size: 0.85rem; color: #64748b;">Qty: <strong><%= quantity %></strong> &times; $<%= product.price.toFixed(2) %></span>
        </div>
        <div style="text-align: right; font-weight: 700; color: #0f172a;">
          $<%= subtotal.toFixed(2) %>
        </div>
      </div>

      <!-- Price Calculations -->
      <div style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.9rem; color: #475569; margin-bottom: 1.5rem;">
        <div style="display: flex; justify-content: space-between;">
          <span>Subtotal</span>
          <span style="font-weight: 600; color: #0f172a;">$<%= subtotal.toFixed(2) %></span>
        </div>
        <div style="display: flex; justify-content: space-between;">
          <span>Shipping & Handling</span>
          <span style="font-weight: 600; color: #0f172a;"><%= shipping === 0 ? 'FREE' : '$' + shipping.toFixed(2) %></span>
        </div>
        <div style="display: flex; justify-content: space-between;">
          <span>Estimated Sales Tax (8%)</span>
          <span style="font-weight: 600; color: #0f172a;">$<%= tax.toFixed(2) %></span>
        </div>
        <div style="display: flex; justify-content: space-between; border-top: 1px solid #e2e8f0; padding-top: 1rem; font-size: 1.1rem; font-weight: 800; color: #0f172a;">
          <span>Total Paid</span>
          <span style="color: #10b981;">$<%= total.toFixed(2) %></span>
        </div>
      </div>

      <!-- Live Stock Feedback Footer -->
      <div style="background-color: #f8fafc; border-radius: 12px; padding: 0.8rem 1.2rem; display: flex; align-items: center; justify-content: space-between; font-size: 0.85rem; border: 1px solid #e2e8f0;">
        <span style="color: #64748b; font-weight: 500;">Inventory Stock Status:</span>
        <span style="font-weight: 700; color: <%= remainingStock === 0 ? '#ef4444' : (remainingStock <= 5 ? '#f59e0b' : '#22c55e') %>;">
          <%= remainingStock === 0 ? 'Out of Stock' : remainingStock + ' Units Remaining' %>
        </span>
      </div>

    </div>

    <!-- Action Buttons -->
    <div style="display: flex; gap: 1.5rem; justify-content: center; margin-top: 3rem;">
      <a href="/products" class="btn-primary" style="padding: 0.8rem 2rem; border-radius: 12px; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; font-weight: 600; cursor: pointer;">
        <i class="fa-solid fa-cart-shopping"></i> Continue Shopping
      </a>
      <button onclick="window.print()" class="btn-outline" style="padding: 0.8rem 2rem; border-radius: 12px; border: 1px solid #cbd5e1; background: #fff; color: #334155; display: flex; align-items: center; gap: 0.5rem; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='#fff'">
        <i class="fa-solid fa-print"></i> Print Invoice
      </button>
    </div>

  </div>

</div>

<!-- Styles for animations -->
<style>
  @keyframes scaleUp {
    0% { transform: scale(0.7); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }
  @keyframes pulseSuccess {
    0% { box-shadow: 0 0 0 0 rgba(220, 252, 231, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(220, 252, 231, 0); }
    100% { box-shadow: 0 0 0 0 rgba(220, 252, 231, 0); }
  }
  @media print {
    body * { visibility: hidden; }
    .invoice-box, .invoice-box * { visibility: visible; }
    .invoice-box { position: absolute; left: 0; top: 0; width: 100%; border: 0; box-shadow: none; padding: 0; }
  }
</style>

<%- include('partials/footer') %>
