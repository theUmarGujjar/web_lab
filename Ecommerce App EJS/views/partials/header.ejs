<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title : 'ShopZone' %></title>
  <meta name="description" content="ShopZone — Shop electronics, clothing, books, and more at unbeatable prices."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <!-- Motion One (Vanilla JS Framer Motion equivalent) -->
  <script src="https://cdn.jsdelivr.net/npm/motion@11.11.13/dist/motion.global.min.js"></script>
</head>
<body>

<!-- ===== TOP HEADER ===== -->
<header class="site-header" id="siteHeader">
  <div class="header-top">
    <div class="header-inner">

      <!-- Logo -->
      <a href="/" class="nav-logo" id="logoLink">
        <span class="logo-icon"><i class="fa-solid fa-bolt"></i></span>
        <span class="logo-text">ShopZone</span>
      </a>

      <!-- Search Bar -->
      <form class="search-form" action="/products" method="GET" id="searchForm">
        <select class="search-cat-select" name="category" id="searchCatSelect" aria-label="Search category">
          <option value="all">All</option>
          <option value="electronics">Electronics</option>
          <option value="clothing">Clothing</option>
          <option value="books">Books</option>
          <option value="home">Home</option>
        </select>
        <input
          type="text"
          class="search-input"
          name="search"
          id="searchInput"
          placeholder="Search products..."
          value="<%= typeof filters !== 'undefined' ? filters.search : '' %>"
          autocomplete="off"
        />
        <button type="submit" class="search-btn" id="searchBtn" aria-label="Search">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </form>

      <!-- Right Actions -->
      <div class="header-actions">
        <button class="hamburger" id="hamburgerBtn" aria-label="Toggle navigation" aria-expanded="false">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
        <a href="#" class="btn-primary cart-btn" id="cartBtn" aria-label="Cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          Cart
          <span class="cart-badge" id="cartBadge">0</span>
        </a>
      </div>

    </div>
  </div>

  <!-- Category Navigation Strip -->
  <nav class="cat-nav" id="catNav" aria-label="Category navigation">
    <div class="cat-nav-inner">
      <a href="/products" class="cat-link <%= typeof filters === 'undefined' || filters.category === 'all' ? 'active' : '' %>">
        All Products
      </a>
      <a href="/products?category=electronics" class="cat-link <%= typeof filters !== 'undefined' && filters.category === 'electronics' ? 'active' : '' %>">
        Electronics
      </a>
      <a href="/products?category=clothing" class="cat-link <%= typeof filters !== 'undefined' && filters.category === 'clothing' ? 'active' : '' %>">
        Clothing
      </a>
      <a href="/products?category=books" class="cat-link <%= typeof filters !== 'undefined' && filters.category === 'books' ? 'active' : '' %>">
        Books
      </a>
      <a href="/products?category=home" class="cat-link <%= typeof filters !== 'undefined' && filters.category === 'home' ? 'active' : '' %>">
        Home &amp; Kitchen
      </a>
      <a href="/products?badge=Deal" class="cat-link">
        Today's Deals
      </a>
    </div>
  </nav>

  <!-- Mobile Nav Menu -->
  <div class="mobile-nav" id="mobileNav">
    <a href="/products" class="mobile-nav-link" id="mNavAll">All Products</a>
    <a href="/products?category=electronics" class="mobile-nav-link" id="mNavElec">Electronics</a>
    <a href="/products?category=clothing"    class="mobile-nav-link" id="mNavCloth">Clothing</a>
    <a href="/products?category=books"       class="mobile-nav-link" id="mNavBooks">Books</a>
    <a href="/products?category=home"        class="mobile-nav-link" id="mNavHome">Home &amp; Kitchen</a>
  </div>
</header>
